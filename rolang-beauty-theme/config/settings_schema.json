[
  {
    "name": "theme_info",
    "theme_name": "ROLANG BEAUTY",
    "theme_version": "1.0.0",
    "theme_author": "ROLANG BEAUTY",
    "theme_documentation_url": "https://github.com/motkimlang76-tech/rolang-beauty",
    "theme_support_url": "https://github.com/motkimlang76-tech/rolang-beauty"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "ROLANG BEAUTY"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Curated Korean skincare shop"
      }
    ]
  },
  {
    "name": "Store support",
    "settings": [
      {
        "type": "text",
        "id": "support_email",
        "label": "Support email",
        "default": "motkimlang76@gmail.com"
      },
      {
        "type": "text",
        "id": "support_phone",
        "label": "Support phone"
      },
      {
        "type": "url",
        "id": "support_whatsapp_url",
        "label": "WhatsApp URL"
      },
      {
        "type": "url",
        "id": "support_instagram_url",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "support_facebook_url",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "support_location",
        "label": "Support location",
        "default": "Phnom Penh City, Cambodia"
      },
      {
        "type": "text",
        "id": "support_hours",
        "label": "Support note",
        "default": "Support is available for product questions, order updates, and shipping help."
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "Secure Shopify checkout for Malaysia and Cambodia."
      },
      {
        "type": "textarea",
        "id": "shipping_note",
        "label": "Shipping note",
        "default": "Orders currently ship to Malaysia and Cambodia. Delivery timing and final rates are shown at checkout before payment is completed."
      },
      {
        "type": "textarea",
        "id": "returns_note",
        "label": "Returns note",
        "default": "Return and refund details are linked from the store policies and support channels."
      }
    ]
  }
]
