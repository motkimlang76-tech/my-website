<div class="rolang-collection-template">
  <div class="rolang-collection-hero">
    <p class="rolang-eyebrow">{{ collection.all_products_count }} products</p>
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="rolang-collection-copy">{{ collection.description }}</div>
    {% else %}
      <p class="rolang-collection-copy">Shop products grouped by brand, routine step, or skin concern.</p>
    {% endif %}
  </div>

  {% paginate collection.products by section.settings.products_per_page %}
    {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}
    {% assign total_products = paginate.items %}
    {% assign visible_products = collection.products.size %}
    {% if total_products > 0 %}
      {% assign visible_start = paginate.current_offset | plus: 1 %}
      {% assign visible_end = paginate.current_offset | plus: visible_products %}
    {% endif %}

    <div class="rolang-product-form-card">
      <div class="rolang-product-form-fields">
        <div>
          <p class="rolang-eyebrow">Sort and browse</p>
          <p aria-live="polite">
            {% if total_products == 1 %}
              Showing 1 product in this collection.
            {% elsif visible_products < total_products %}
              Showing {{ visible_start }}-{{ visible_end }} of {{ total_products }} products in this collection.
            {% else %}
              {{ total_products }} products available in this collection.
            {% endif %}
            {% if paginate.pages > 1 %}
              Page {{ paginate.current_page }} of {{ paginate.pages }}.
            {% endif %}
          </p>
        </div>

        <form action="{{ request.path }}" method="get">
          <div class="rolang-field-group">
            <label for="SortBy-{{ section.id }}">Sort products</label>
            <select id="SortBy-{{ section.id }}" name="sort_by">
              {% for option in collection.sort_options %}
                <option
                  value="{{ option.value }}"
                  {% if option.value == current_sort %}
                    selected="selected"
                  {% endif %}
                >
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          </div>

          <div class="rolang-cart-actions">
            <button class="rolang-button-quiet" type="submit">Apply sort</button>
            {% if collection.handle != 'all' %}
              <a class="rolang-inline-link" href="{{ routes.all_products_collection_url }}">Browse all products</a>
            {% endif %}
          </div>
        </form>
      </div>
    </div>

    {% if paginate.items == 0 %}
      <div class="rolang-product-form-card">
        <div class="rolang-product-form-fields">
          <div>
            <p class="rolang-eyebrow">Nothing here yet</p>
            <p>This collection is being updated. Browse the full catalog while new products are added.</p>
          </div>

          <div class="rolang-cart-actions">
            <a class="rolang-button-secondary" href="{{ routes.all_products_collection_url }}">Browse all products</a>
            <a class="rolang-button-quiet" href="{{ routes.search_url }}">Search the catalog</a>
          </div>
        </div>
      </div>
    {% else %}
      <div class="rolang-product-grid">
        {% for product in collection.products %}
          {% assign collection_card_variant = product.selected_or_first_available_variant %}
          {% capture collection_card_availability %}
            {% if product.available and collection_card_variant %}
              {% if collection_card_variant.inventory_management != blank %}
                {% if collection_card_variant.inventory_quantity > 0 %}
                  In stock
                {% elsif collection_card_variant.inventory_policy == 'continue' %}
                  Available to order
                {% else %}
                  Currently sold out
                {% endif %}
              {% else %}
                Available
              {% endif %}
            {% else %}
              Currently sold out
            {% endif %}
          {% endcapture %}
          <article class="rolang-product-card">
            <div class="rolang-product-card-image">
              {% if product.featured_image %}
                {% render 'image',
                  image: product.featured_image,
                  url: product.url,
                  width: 640,
                  height: 640,
                  crop: 'center'
                %}
              {% endif %}
            </div>
            <div class="rolang-product-card-copy">
              <span class="rolang-product-meta">{{ product.vendor | default: shop.name }}</span>
              <strong>{{ product.title }}</strong>
              <div class="rolang-price-row">
                <span class="rolang-price">
                  {% if product.price_varies %}
                    From {{ product.price_min | money }}
                  {% else %}
                    {{ product.price | money }}
                  {% endif %}
                </span>
                {% if product.compare_at_price > product.price %}
                  <span class="rolang-compare-price">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
              <div class="rolang-detail-row">
                <span class="rolang-detail-pill">{{ collection_card_availability | strip }}</span>
                {% if product.variants.size > 1 %}
                  <span class="rolang-detail-pill">{{ product.variants.size }} options</span>
                {% endif %}
              </div>
              {% render 'product-tag-chips', product: product, limit: 3 %}
              <a class="rolang-button-quiet rolang-card-action" href="{{ product.url }}">View product</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {{ paginate | default_pagination }}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16
    }
  ]
}
{% endschema %}
