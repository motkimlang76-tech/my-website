<div class="rolang-collection-template">
  <div class="rolang-collection-hero">
    <p class="rolang-eyebrow">{{ collection.all_products_count }} products</p>
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="rolang-collection-copy">{{ collection.description }}</div>
    {% else %}
      <p class="rolang-collection-copy">
        Use Shopify collections to group products by brand, skin type, or routine without rebuilding the storefront.
      </p>
    {% endif %}
  </div>

  {% paginate collection.products by section.settings.products_per_page %}
    <div class="rolang-product-grid">
      {% for product in collection.products %}
        <article class="rolang-product-card">
          <div class="rolang-product-card-image">
            {% if product.featured_image %}
              {% render 'image',
                image: product.featured_image,
                url: product.url,
                width: 640,
                height: 640,
                crop: 'center'
              %}
            {% endif %}
          </div>
          <div class="rolang-product-card-copy">
            <span class="rolang-product-meta">{{ product.vendor | default: shop.name }}</span>
            <strong>{{ product.title }}</strong>
            <div class="rolang-price-row">
              <span class="rolang-price">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="rolang-compare-price">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
            <div class="rolang-tag-row">
              {% for tag in product.tags limit: 3 %}
                <span class="rolang-chip">{{ tag }}</span>
              {% endfor %}
            </div>
            <a class="rolang-inline-link" href="{{ product.url }}">View product</a>
          </div>
        </article>
      {% endfor %}
    </div>

    {{ paginate | default_pagination }}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16
    }
  ]
}
{% endschema %}
