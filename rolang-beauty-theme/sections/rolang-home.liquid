{% liquid
  assign note_blocks = section.blocks | where: 'type', 'note'
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign brand_blocks = section.blocks | where: 'type', 'brand'
  assign hero_products = section.settings.hero_products
  assign featured_collection = section.settings.featured_collection
  assign spotlight_collection_one = section.settings.spotlight_collection_one
  assign spotlight_collection_two = section.settings.spotlight_collection_two
  assign spotlight_collection_three = section.settings.spotlight_collection_three
  assign spotlight_collection_four = section.settings.spotlight_collection_four
  if featured_collection == blank and collections['all'] != blank and collections['all'].products_count > 0
    assign featured_collection = collections['all']
  endif
  assign panel_items_markup = section.settings.panel_items | replace: '\n', '<br />' | newline_to_br
  assign panel_items = panel_items_markup | split: '<br />'
  assign support_email = section.settings.contact_email | default: settings.support_email | default: shop.email
  assign support_whatsapp_url = settings.support_whatsapp_url
  assign support_instagram_url = settings.support_instagram_url
  assign support_facebook_url = settings.support_facebook_url
  assign support_location = settings.support_location
  assign support_hours = settings.support_hours
  assign shipping_policy = shop.shipping_policy
  assign refund_policy = shop.refund_policy
  assign showcase_fallback_url = section.settings.collection_cta_url | default: section.settings.primary_url | default: routes.all_products_collection_url
  assign hero_highlights_markup = section.settings.hero_highlights | replace: '\n', '<br />' | newline_to_br
  assign hero_highlights = hero_highlights_markup | split: '<br />'
  assign trust_items_markup = section.settings.trust_items | replace: '\n', '<br />' | newline_to_br
  assign trust_items = trust_items_markup | split: '<br />'
  assign has_social_cta = false
  if support_whatsapp_url != blank or support_instagram_url != blank or support_facebook_url != blank
    assign has_social_cta = true
  endif
%}

<div class="rolang-section-frame">
  <div class="rolang-home-shell">
    <section class="rolang-hero">
      <div class="rolang-hero-copy">
        <p class="rolang-eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="rolang-heading">{{ section.settings.heading }}</h1>
        <p class="rolang-lede">{{ section.settings.description }}</p>

        {% if note_blocks.size > 0 %}
          <div class="rolang-chip-row">
            {% for block in note_blocks %}
              <span class="rolang-chip" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
            {% endfor %}
          </div>
        {% endif %}

        <div class="rolang-hero-actions">
          {% if section.settings.primary_label != blank and section.settings.primary_url != blank %}
            <a class="rolang-button" href="{{ section.settings.primary_url }}">{{ section.settings.primary_label }}</a>
          {% endif %}
          {% if section.settings.secondary_label != blank and section.settings.secondary_url != blank %}
            <a class="rolang-button-secondary" href="{{ section.settings.secondary_url }}">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>

        {% if hero_highlights.size > 0 and hero_highlights.first != blank %}
          <div class="rolang-hero-highlights">
            {% if section.settings.hero_highlights_heading != blank %}
              <p class="rolang-small-copy">{{ section.settings.hero_highlights_heading }}</p>
            {% endif %}
            <div class="rolang-chip-row rolang-chip-row--tight">
              {% for highlight in hero_highlights %}
                {% assign highlight_text = highlight | strip %}
                {% if highlight_text != blank %}
                  <span class="rolang-chip">{{ highlight_text }}</span>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>

      <aside class="rolang-hero-panel">
        <div>
          <p class="rolang-eyebrow">{{ section.settings.panel_eyebrow }}</p>
          <h2 class="rolang-panel-heading">{{ section.settings.panel_title }}</h2>
          <p class="rolang-panel-copy">{{ section.settings.panel_description }}</p>
        </div>

        <div class="rolang-showcase-grid">
          {% if hero_products != blank %}
            {% for product in hero_products limit: 3 %}
              <a class="rolang-showcase-card rolang-showcase-card-link" href="{{ product.url }}" aria-label="View {{ product.title }}">
                <div class="rolang-showcase-media">
                  {% if product.featured_image %}
                    {% render 'image', image: product.featured_image, width: 320, height: 320, crop: 'center' %}
                  {% endif %}
                </div>
                <div class="rolang-showcase-copy">
                  <strong>{{ product.vendor | default: shop.name }}</strong>
                  <span>{{ product.title }}</span>
                </div>
              </a>
            {% endfor %}
          {% elsif featured_collection != blank and featured_collection.products_count > 0 %}
            {% for product in featured_collection.products limit: 3 %}
              <a class="rolang-showcase-card rolang-showcase-card-link" href="{{ product.url }}" aria-label="View {{ product.title }}">
                <div class="rolang-showcase-media">
                  {% if product.featured_image %}
                    {% render 'image', image: product.featured_image, width: 320, height: 320, crop: 'center' %}
                  {% endif %}
                </div>
                <div class="rolang-showcase-copy">
                  <strong>{{ product.vendor | default: shop.name }}</strong>
                  <span>{{ product.title }}</span>
                </div>
              </a>
            {% endfor %}
          {% else %}
            <a class="rolang-showcase-card rolang-showcase-card-link" href="{{ showcase_fallback_url }}" aria-label="Browse the featured collection">
              <div class="rolang-showcase-media">
                <img
                  src="{{ 'skin1004-centella-ampoule.png' | asset_url }}"
                  alt="SKIN1004 Madagascar Centella Ampoule bottle"
                  loading="lazy"
                  width="320"
                  height="320"
                >
              </div>
              <div class="rolang-showcase-copy">
                <strong>SKIN1004</strong>
                <span>Centella Ampoule</span>
              </div>
            </a>

            <a class="rolang-showcase-card rolang-showcase-card-link" href="{{ showcase_fallback_url }}" aria-label="Browse the featured collection">
              <div class="rolang-showcase-media">
                <img
                  src="{{ 'cosrx-advanced-snail-96-mucin-essence.jpg' | asset_url }}"
                  alt="COSRX Advanced Snail 96 Mucin Essence bottle"
                  loading="lazy"
                  width="320"
                  height="320"
                >
              </div>
              <div class="rolang-showcase-copy">
                <strong>COSRX</strong>
                <span>Snail 96 Mucin Essence</span>
              </div>
            </a>

            <a class="rolang-showcase-card rolang-showcase-card-link" href="{{ showcase_fallback_url }}" aria-label="Browse the featured collection">
              <div class="rolang-showcase-media">
                <img
                  src="{{ 'medicube-collagen-niacinamide-jelly-cream.jpg' | asset_url }}"
                  alt="Medicube Collagen Niacinamide Jelly Cream jar"
                  loading="lazy"
                  width="320"
                  height="320"
                >
              </div>
              <div class="rolang-showcase-copy">
                <strong>Medicube</strong>
                <span>Collagen Niacinamide Jelly Cream</span>
              </div>
            </a>
          {% endif %}
        </div>

        {% if section.settings.panel_items != blank %}
          <ul class="rolang-panel-list">
            {% for item in panel_items %}
              {% assign clean_item = item | strip %}
              {% if clean_item != blank %}
                <li>{{ clean_item }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </aside>
    </section>

    {% if spotlight_collection_one != blank or spotlight_collection_two != blank or spotlight_collection_three != blank or spotlight_collection_four != blank %}
      <section class="rolang-collection-spotlight">
        <div class="rolang-section-heading">
          <p class="rolang-eyebrow">{{ section.settings.spotlight_eyebrow }}</p>
          <h2>{{ section.settings.spotlight_heading }}</h2>
          {% if section.settings.spotlight_description != blank %}
            <p>{{ section.settings.spotlight_description }}</p>
          {% endif %}
        </div>

        <div class="rolang-collections-spotlight-grid">
          {% if spotlight_collection_one != blank %}
            {% assign spotlight_image = spotlight_collection_one.featured_image %}
            {% if spotlight_image == blank and spotlight_collection_one.products_count > 0 %}
              {% assign spotlight_image = spotlight_collection_one.products.first.featured_image %}
            {% endif %}
            <a class="rolang-collection-spotlight-card" href="{{ spotlight_collection_one.url }}">
              {% if spotlight_image %}
                <div class="rolang-collection-spotlight-image">
                  {% render 'image', image: spotlight_image, width: 720, height: 720, crop: 'center' %}
                </div>
              {% endif %}
              <div class="rolang-collection-spotlight-copy">
                <span class="rolang-product-meta">{{ spotlight_collection_one.all_products_count }} products</span>
                <strong>{{ spotlight_collection_one.title }}</strong>
                {% if spotlight_collection_one.description != blank %}
                  <p>{{ spotlight_collection_one.description | strip_html | truncatewords: 16 }}</p>
                {% else %}
                  <p>Shop this curated collection.</p>
                {% endif %}
              </div>
            </a>
          {% endif %}

          {% if spotlight_collection_two != blank %}
            {% assign spotlight_image = spotlight_collection_two.featured_image %}
            {% if spotlight_image == blank and spotlight_collection_two.products_count > 0 %}
              {% assign spotlight_image = spotlight_collection_two.products.first.featured_image %}
            {% endif %}
            <a class="rolang-collection-spotlight-card" href="{{ spotlight_collection_two.url }}">
              {% if spotlight_image %}
                <div class="rolang-collection-spotlight-image">
                  {% render 'image', image: spotlight_image, width: 720, height: 720, crop: 'center' %}
                </div>
              {% endif %}
              <div class="rolang-collection-spotlight-copy">
                <span class="rolang-product-meta">{{ spotlight_collection_two.all_products_count }} products</span>
                <strong>{{ spotlight_collection_two.title }}</strong>
                {% if spotlight_collection_two.description != blank %}
                  <p>{{ spotlight_collection_two.description | strip_html | truncatewords: 16 }}</p>
                {% else %}
                  <p>Shop this curated collection.</p>
                {% endif %}
              </div>
            </a>
          {% endif %}

          {% if spotlight_collection_three != blank %}
            {% assign spotlight_image = spotlight_collection_three.featured_image %}
            {% if spotlight_image == blank and spotlight_collection_three.products_count > 0 %}
              {% assign spotlight_image = spotlight_collection_three.products.first.featured_image %}
            {% endif %}
            <a class="rolang-collection-spotlight-card" href="{{ spotlight_collection_three.url }}">
              {% if spotlight_image %}
                <div class="rolang-collection-spotlight-image">
                  {% render 'image', image: spotlight_image, width: 720, height: 720, crop: 'center' %}
                </div>
              {% endif %}
              <div class="rolang-collection-spotlight-copy">
                <span class="rolang-product-meta">{{ spotlight_collection_three.all_products_count }} products</span>
                <strong>{{ spotlight_collection_three.title }}</strong>
                {% if spotlight_collection_three.description != blank %}
                  <p>{{ spotlight_collection_three.description | strip_html | truncatewords: 16 }}</p>
                {% else %}
                  <p>Shop this curated collection.</p>
                {% endif %}
              </div>
            </a>
          {% endif %}

          {% if spotlight_collection_four != blank %}
            {% assign spotlight_image = spotlight_collection_four.featured_image %}
            {% if spotlight_image == blank and spotlight_collection_four.products_count > 0 %}
              {% assign spotlight_image = spotlight_collection_four.products.first.featured_image %}
            {% endif %}
            <a class="rolang-collection-spotlight-card" href="{{ spotlight_collection_four.url }}">
              {% if spotlight_image %}
                <div class="rolang-collection-spotlight-image">
                  {% render 'image', image: spotlight_image, width: 720, height: 720, crop: 'center' %}
                </div>
              {% endif %}
              <div class="rolang-collection-spotlight-copy">
                <span class="rolang-product-meta">{{ spotlight_collection_four.all_products_count }} products</span>
                <strong>{{ spotlight_collection_four.title }}</strong>
                {% if spotlight_collection_four.description != blank %}
                  <p>{{ spotlight_collection_four.description | strip_html | truncatewords: 16 }}</p>
                {% else %}
                  <p>Shop this curated collection.</p>
                {% endif %}
              </div>
            </a>
          {% endif %}
        </div>
      </section>
    {% endif %}

    {% if trust_items.size > 0 and trust_items.first != blank %}
      <section class="rolang-trust-grid">
        <div class="rolang-section-heading">
          <p class="rolang-eyebrow">{{ section.settings.trust_eyebrow }}</p>
          <h2>{{ section.settings.trust_heading }}</h2>
          <p>{{ section.settings.trust_description }}</p>
        </div>
        <div class="rolang-trust-cards">
          {% for item in trust_items %}
            {% assign parts = item | split: '||' %}
            {% assign trust_title = parts[0] | strip %}
            {% assign trust_body = parts[1] | strip %}
            {% if trust_title != blank %}
              <article class="rolang-soft-card rolang-trust-card">
                <strong>{{ trust_title }}</strong>
                {% if trust_body != blank %}
                  <p>{{ trust_body }}</p>
                {% endif %}
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if stat_blocks.size > 0 %}
      <section class="rolang-stats-grid">
        {% for block in stat_blocks %}
          <article class="rolang-soft-card" {{ block.shopify_attributes }}>
            <strong class="rolang-stat-value">{{ block.settings.value }}</strong>
            <p class="rolang-stat-label">{{ block.settings.label }}</p>
          </article>
        {% endfor %}
      </section>
    {% endif %}

    <section class="rolang-content-cluster">
      {% if step_blocks.size > 0 %}
        <div>
          <div class="rolang-section-heading">
            <p class="rolang-eyebrow">{{ section.settings.steps_eyebrow }}</p>
            <h2>{{ section.settings.steps_heading }}</h2>
            <p>{{ section.settings.steps_description }}</p>
          </div>
          <div class="rolang-steps-grid">
            {% for block in step_blocks %}
              <article class="rolang-soft-card rolang-step-card" {{ block.shopify_attributes }}>
                <span class="rolang-step-number">{{ forloop.index }}</span>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.description }}</p>
              </article>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% if brand_blocks.size > 0 %}
        <div>
          <div class="rolang-section-heading">
            <p class="rolang-eyebrow">{{ section.settings.brands_eyebrow }}</p>
            <h2>{{ section.settings.brands_heading }}</h2>
            <p>{{ section.settings.brands_description }}</p>
          </div>
          <div class="rolang-brands-grid">
            {% for block in brand_blocks %}
              <article class="rolang-soft-card rolang-brand-card" {{ block.shopify_attributes }}>
                <span class="rolang-brand-pill">{{ block.settings.name }}</span>
                <h3>{{ block.settings.title }}</h3>
                <p class="rolang-brand-note">{{ block.settings.note }}</p>
              </article>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </section>

    <section class="rolang-collection-card">
      <div class="rolang-section-heading">
        <p class="rolang-eyebrow">{{ section.settings.collection_eyebrow }}</p>
        <h2>{{ section.settings.collection_heading }}</h2>
        <p>{{ section.settings.collection_description }}</p>
      </div>
      {% assign collection_cta_target = section.settings.collection_cta_url %}
      {% if collection_cta_target == blank and featured_collection != blank %}
        {% assign collection_cta_target = featured_collection.url %}
      {% endif %}
      {% if section.settings.collection_highlight != blank or section.settings.collection_cta_label != blank %}
        <div class="rolang-collection-promo">
          {% if section.settings.collection_highlight != blank %}
            <p class="rolang-subcopy">{{ section.settings.collection_highlight }}</p>
          {% endif %}
          {% if section.settings.collection_cta_label != blank and collection_cta_target != blank %}
            <a class="rolang-inline-link" href="{{ collection_cta_target }}">
              {{ section.settings.collection_cta_label }}
            </a>
          {% elsif featured_collection != blank %}
            <a class="rolang-inline-link" href="{{ featured_collection.url }}">View collection</a>
          {% endif %}
        </div>
      {% endif %}

      {% if featured_collection != blank %}
        <div class="rolang-product-grid">
          {% for product in featured_collection.products limit: section.settings.products_to_show %}
            <article class="rolang-product-card">
              <div class="rolang-product-card-image">
                {% if product.featured_image %}
                  {% render 'image',
                    image: product.featured_image,
                    url: product.url,
                    width: 640,
                    height: 640,
                    crop: 'center'
                  %}
                {% endif %}
              </div>
              <div class="rolang-product-card-copy">
                <span class="rolang-product-meta">{{ product.vendor | default: shop.name }}</span>
                <strong>{{ product.title }}</strong>
                <div class="rolang-price-row">
                  <span class="rolang-price">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="rolang-compare-price">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
                {% render 'product-tag-chips', product: product, limit: 3 %}
                <a class="rolang-inline-link" href="{{ product.url }}">View product</a>
              </div>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <div class="rolang-collection-placeholder">
          Import products into Shopify or choose a featured collection in the theme editor to populate this section.
        </div>
      {% endif %}
    </section>

    <section class="rolang-contact-card">
      <div>
        <p class="rolang-eyebrow">{{ section.settings.contact_eyebrow }}</p>
        <h2>{{ section.settings.contact_heading }}</h2>
        <p>{{ section.settings.contact_description }}</p>

        {% if support_location != blank or support_hours != blank %}
          <div class="rolang-inline-link-row rolang-inline-link-row--muted">
            {% if support_location != blank %}
              <span class="rolang-support-pill">{{ support_location }}</span>
            {% endif %}
            {% if support_hours != blank %}
              <span class="rolang-support-pill">{{ support_hours }}</span>
            {% endif %}
          </div>
        {% endif %}

        {% if shipping_policy.body != blank or refund_policy.body != blank %}
          <div class="rolang-inline-link-row">
            {% if shipping_policy.body != blank %}
              <a class="rolang-inline-link" href="{{ shipping_policy.url }}">Shipping policy</a>
            {% endif %}
            {% if refund_policy.body != blank %}
              <a class="rolang-inline-link" href="{{ refund_policy.url }}">Refund policy</a>
            {% endif %}
          </div>
        {% endif %}
      </div>
      <div class="rolang-contact-actions">
        {% if support_whatsapp_url != blank %}
          <a class="rolang-button" href="{{ support_whatsapp_url }}" target="_blank" rel="noopener">
            Chat on WhatsApp
          </a>
        {% endif %}
        {% if support_instagram_url != blank %}
          <a class="rolang-button-secondary" href="{{ support_instagram_url }}" target="_blank" rel="noopener">
            Instagram
          </a>
        {% endif %}
        {% if support_facebook_url != blank %}
          <a class="rolang-button-secondary" href="{{ support_facebook_url }}" target="_blank" rel="noopener">
            Facebook
          </a>
        {% endif %}
        {% if section.settings.contact_link_label != blank and section.settings.contact_link_url != blank %}
          <a
            class="{% if has_social_cta %}rolang-button-secondary{% else %}rolang-button{% endif %}"
            href="{{ section.settings.contact_link_url }}"
          >
            {{ section.settings.contact_link_label }}
          </a>
        {% endif %}
        {% if support_email != blank %}
          <p class="rolang-small-copy">
            Email support:
            <a class="rolang-inline-link" href="mailto:{{ support_email }}">{{ support_email }}</a>
          </p>
        {% endif %}
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "ROLANG home",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero eyebrow",
      "default": "Phnom Penh City, Cambodia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hero heading",
      "default": "A softer way to shop Korean skincare online."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Hero description",
      "default": "ROLANG BEAUTY is an online Korean beauty shop based in Phnom Penh City, Cambodia. Browse Korean skincare collections, real product pages, and Shopify checkout for Malaysia and Cambodia."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop all products"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Contact the shop"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "hero_highlights_heading",
      "label": "Hero highlights heading",
      "default": "What is live now"
    },
    {
      "type": "textarea",
      "id": "hero_highlights",
      "label": "Hero highlights (one per line)",
      "default": "48 products live\nMalaysia + Cambodia support\nShopify checkout ready"
    },
    {
      "type": "text",
      "id": "panel_eyebrow",
      "label": "Panel eyebrow",
      "default": "Starter set"
    },
    {
      "type": "text",
      "id": "panel_title",
      "label": "Panel title",
      "default": "Three steps for a clean, calm everyday routine."
    },
    {
      "type": "textarea",
      "id": "panel_description",
      "label": "Panel description",
      "default": "Start with soothing care, layer in hydration, and finish with lightweight daily protection. You can keep the curated look of the original site while using Shopify products and checkout."
    },
    {
      "type": "textarea",
      "id": "panel_items",
      "label": "Panel list items",
      "default": "Centella Light Cleansing Oil\nMadagascar Centella Ampoule\nHyalu-Cica Water-Fit Sun Serum"
    },
    {
      "type": "product_list",
      "id": "hero_products",
      "label": "Hero products"
    },
    {
      "type": "text",
      "id": "trust_eyebrow",
      "label": "Trust eyebrow",
      "default": "ROLANG assurance"
    },
    {
      "type": "text",
      "id": "trust_heading",
      "label": "Trust heading",
      "default": "Why shop with Rolang Beauty"
    },
    {
      "type": "textarea",
      "id": "trust_description",
      "label": "Trust description",
      "default": "Each product page includes clear descriptions, ingredient context, and direct support from the Rolang team."
    },
    {
      "type": "textarea",
      "id": "trust_items",
      "label": "Trust items (title||description per line)",
      "default": "Malaysia + Cambodia||The store is currently set up to support shoppers in Malaysia and Cambodia.\nClear collection paths||Browse by cleanser, sunscreen, toner, serum, cream, calming care, brightening, or targeted treatment.\nPolicy-backed checkout||Shipping and return details stay linked from Shopify during checkout."
    },
    {
      "type": "text",
      "id": "steps_eyebrow",
      "label": "Steps eyebrow",
      "default": "Start here"
    },
    {
      "type": "text",
      "id": "steps_heading",
      "label": "Steps heading",
      "default": "Guide customers from first impression to checkout."
    },
    {
      "type": "textarea",
      "id": "steps_description",
      "label": "Steps description",
      "default": "Use the homepage to explain the shop quickly, then move customers into collections, products, cart, and checkout."
    },
    {
      "type": "text",
      "id": "brands_eyebrow",
      "label": "Brands eyebrow",
      "default": "Brands"
    },
    {
      "type": "text",
      "id": "brands_heading",
      "label": "Brands heading",
      "default": "Featured Korean skincare brands in the current shop edit."
    },
    {
      "type": "textarea",
      "id": "brands_description",
      "label": "Brands description",
      "default": "Keep the curated K-beauty positioning of the original site while attaching real products to each collection."
    },
    {
      "type": "text",
      "id": "collection_eyebrow",
      "label": "Collection eyebrow",
      "default": "Shop the edit"
    },
    {
      "type": "text",
      "id": "collection_heading",
