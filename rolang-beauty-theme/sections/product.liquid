{% assign current_variant = product.selected_or_first_available_variant %}
{% assign support_email = settings.support_email | default: shop.email %}
{% assign support_whatsapp_url = settings.support_whatsapp_url %}
{% assign support_instagram_url = settings.support_instagram_url %}
{% assign support_facebook_url = settings.support_facebook_url %}
{% assign support_location = settings.support_location %}
{% assign shipping_note = settings.shipping_note %}
{% assign returns_note = settings.returns_note %}
{% assign shipping_policy = shop.shipping_policy %}
{% assign refund_policy = shop.refund_policy %}
{% assign has_support_contact = false %}
{% if support_whatsapp_url != blank
  or support_instagram_url != blank
  or support_facebook_url != blank
  or support_email != blank
%}
  {% assign has_support_contact = true %}
{% endif %}
{% capture shipping_guidance %}
  {% if shipping_note != blank %}
    {{ shipping_note }}
  {% elsif shipping_policy.body != blank %}
    Shipping destinations, delivery timing, and final rates are shown in the shipping policy and at checkout before payment is completed.
  {% endif %}
{% endcapture %}
{% capture returns_guidance %}
  {% if refund_policy.body != blank and returns_note != blank %}
    {{ returns_note }}
  {% elsif refund_policy.body != blank %}
    Return and refund details stay available through the refund policy and support links below.
  {% elsif has_support_contact %}
    Questions about returns or refunds can be sent through the support links below before checkout.
  {% endif %}
{% endcapture %}
{% capture current_variant_availability %}
  {% if current_variant.available %}
      {% if current_variant.inventory_management != blank %}
        {% if current_variant.inventory_quantity > 0 %}
          {% if current_variant.inventory_quantity <= 5 %}
            Only {{ current_variant.inventory_quantity }} left
          {% else %}
            In stock
          {% endif %}
        {% elsif current_variant.inventory_policy == 'continue' %}
          In stock
        {% else %}
          Currently sold out
        {% endif %}
      {% else %}
        In stock
      {% endif %}
  {% else %}
    Currently sold out
  {% endif %}
{% endcapture %}

<div class="rolang-product-template" data-product-section="{{ section.id }}">
  <div class="rolang-product-gallery">
    {% if product.featured_image %}
      <div class="rolang-product-primary-media">
        {% render 'image', image: product.featured_image, width: 1200, height: 1200, crop: 'center' %}
      </div>
    {% endif %}

    {% if product.images.size > 1 %}
      <div class="rolang-product-thumb-grid">
        {% for image in product.images offset: 1 limit: 6 %}
          <div class="rolang-product-thumb">
            {% render 'image', image: image, width: 480, height: 480, crop: 'center' %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="rolang-product-summary">
    <p class="rolang-eyebrow">{{ product.vendor | default: shop.name }}</p>
    <h1>{{ product.title }}</h1>

    <div class="rolang-price-stack" role="status" aria-live="polite">
      <span class="rolang-price" data-product-price>{{ current_variant.price | money }}</span>
      <span
        class="rolang-compare-price"
        data-product-compare-price
        {% unless current_variant.compare_at_price > current_variant.price %}
          hidden
        {% endunless %}
      >
        {% if current_variant.compare_at_price > current_variant.price %}
          {{ current_variant.compare_at_price | money }}
        {% endif %}
      </span>
    </div>

    <div class="rolang-detail-row">
      <span class="rolang-detail-pill" data-product-availability role="status" aria-live="polite" aria-atomic="true">{{ current_variant_availability | strip }}</span>
      <span
        class="rolang-detail-pill"
        data-product-sku
        {% if current_variant.sku == blank %}
          hidden
        {% endif %}
      >
        {% if current_variant.sku != blank %}
          SKU {{ current_variant.sku }}
        {% endif %}
      </span>
      {% if product.type != blank %}
        <span class="rolang-detail-pill">{{ product.type }}</span>
      {% endif %}
    </div>

    {% render 'product-tag-chips', product: product, limit: 6 %}

    <div class="rolang-rte">
      {{ product.description }}
    </div>

    <div class="rolang-product-form-card">
      {% form 'product', product %}
        <div class="rolang-product-form-fields">
          {% unless product.has_only_default_variant %}
            <div class="rolang-field-group">
              <label for="Variant-{{ section.id }}">Variant</label>
              <select id="Variant-{{ section.id }}" name="id">
                {% for variant in product.variants %}
                  {% capture variant_availability %}
                    {% if variant.available %}
                      {% if variant.inventory_management != blank %}
                        {% if variant.inventory_quantity > 0 %}
                          {% if variant.inventory_quantity <= 5 %}
                            Only {{ variant.inventory_quantity }} left
                          {% else %}
                            In stock
                          {% endif %}
                        {% elsif variant.inventory_policy == 'continue' %}
                          In stock
                        {% else %}
                          Currently sold out
                        {% endif %}
                      {% else %}
                        In stock
                      {% endif %}
                    {% else %}
                      Currently sold out
                    {% endif %}
                  {% endcapture %}
                  <option
                    value="{{ variant.id }}"
                    data-price="{{ variant.price | money | escape }}"
                    data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | escape }}{% endif %}"
                    data-available="{{ variant.available }}"
                    data-availability="{{ variant_availability | strip | escape }}"
                    data-sku="{{ variant.sku | escape }}"
                    {% if variant == current_variant %}
                      selected="selected"
                    {% endif %}
                    {% unless variant.available %}
                      disabled="disabled"
                    {% endunless %}
                  >
                    {{ variant.title }} - {{ variant.price | money }}
                    {% unless variant.available %}
                      - Sold out
                    {% endunless %}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% endunless %}

          <div class="rolang-field-group">
            <label for="Quantity-{{ section.id }}">Quantity</label>
            <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
          </div>

          <div class="rolang-product-form-actions">
            <button
              class="rolang-button rolang-button--wide"
              data-product-submit
              type="submit"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
            >
              {% if current_variant.available %}
                Add to cart
              {% else %}
                Sold out
              {% endif %}
            </button>
            {% if section.settings.show_dynamic_checkout %}
              {{ form | payment_button }}
            {% endif %}
          </div>
        </div>
      {% endform %}
    </div>

    <div class="rolang-trust-card">
      <p class="rolang-eyebrow">Store support</p>
      <ul class="rolang-trust-list">
        <li>Secure checkout and order confirmation are handled through Shopify.</li>
        {% if shipping_guidance != blank %}
          <li>{{ shipping_guidance | strip }}</li>
        {% endif %}
        {% if returns_guidance != blank %}
          <li>{{ returns_guidance | strip }}</li>
        {% endif %}
        {% if support_location != blank %}
          <li>Store support base: {{ support_location }}</li>
        {% endif %}
      </ul>

      <div class="rolang-inline-link-row">
        {% if shipping_policy.body != blank %}
          <a class="rolang-inline-link" href="{{ shipping_policy.url }}">Shipping policy</a>
        {% endif %}
        {% if refund_policy.body != blank %}
          <a class="rolang-inline-link" href="{{ refund_policy.url }}">Refund policy</a>
        {% endif %}
        {% if support_whatsapp_url != blank %}
          <a class="rolang-inline-link" href="{{ support_whatsapp_url }}" target="_blank" rel="noopener">WhatsApp</a>
        {% endif %}
        {% if support_instagram_url != blank %}
          <a class="rolang-inline-link" href="{{ support_instagram_url }}" target="_blank" rel="noopener">Instagram</a>
        {% endif %}
        {% if support_facebook_url != blank %}
          <a class="rolang-inline-link" href="{{ support_facebook_url }}" target="_blank" rel="noopener">Facebook</a>
        {% endif %}
        {% if support_email != blank %}
          <a class="rolang-inline-link" href="mailto:{{ support_email }}">Email support</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% unless product.has_only_default_variant %}
  <script>
    (() => {
      const root = document.querySelector('[data-product-section="{{ section.id }}"]');
      if (!root) return;

      const variantSelect = root.querySelector('#Variant-{{ section.id }}');
      if (!variantSelect) return;

      const price = root.querySelector('[data-product-price]');
      const comparePrice = root.querySelector('[data-product-compare-price]');
      const availability = root.querySelector('[data-product-availability]');
      const sku = root.querySelector('[data-product-sku]');
      const submitButton = root.querySelector('[data-product-submit]');

      const updateSelectedVariant = () => {
        const option = variantSelect.options[variantSelect.selectedIndex];
        if (!option) return;

        if (price) {
          price.textContent = option.dataset.price || '';
        }

        if (comparePrice) {
          const compareValue = option.dataset.comparePrice || '';
          comparePrice.textContent = compareValue;
          comparePrice.hidden = compareValue === '';
        }

        if (availability) {
          availability.textContent = option.dataset.availability || '';
        }

        if (sku) {
          const skuValue = option.dataset.sku || '';
          sku.textContent = skuValue ? `SKU ${skuValue}` : '';
          sku.hidden = skuValue === '';
        }

        if (submitButton) {
          const isAvailable = option.dataset.available === 'true';
          submitButton.disabled = !isAvailable;
          submitButton.textContent = isAvailable ? 'Add to cart' : 'Sold out';
        }
      };

      variantSelect.addEventListener('change', updateSelectedVariant);
      updateSelectedVariant();
    })();
  </script>
{% endunless %}

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
