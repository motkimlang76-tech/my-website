{% assign brand_name = settings.brand_name | default: shop.name %}
{% assign contact_email = shop.email | default: 'motkimlang76@gmail.com' %}

<div class="rolang-password-page" data-theme-build="rolang-20260415">
  <div class="rolang-password-shell">
    <section class="rolang-password-copy">
      <div class="rolang-password-brand">
        <span class="rolang-brand-mark">
          <img src="{{ 'rolang-brand-photo-badge.jpeg' | asset_url }}" alt="{{ brand_name }}" width="160" height="160">
        </span>
        <div class="rolang-brand-copy">
          <strong>{{ brand_name }}</strong>
          <span>{{ settings.brand_tagline | default: 'Korean skincare launch edit' }}</span>
        </div>
      </div>

      <p class="rolang-eyebrow">Launch Preview</p>
      <h1 class="rolang-heading">The first Rolang Beauty storefront is live and almost public.</h1>
      <p class="rolang-lede">
        The initial Korean skincare launch is loaded into Shopify with real product pages, prices, cart, and
        collection browsing. Enter the password below to preview the store while final public access is being opened.
      </p>

      <div class="rolang-chip-row">
        <span class="rolang-chip">11 launch products</span>
        <span class="rolang-chip">SKIN1004 + COSRX + Isntree + ANUA + Medicube</span>
        <span class="rolang-chip">Calming care, SPF, and treatment picks</span>
      </div>

      <div class="rolang-password-support">
        <p>
          Need early access or product help?
        </p>
        <a class="rolang-button-secondary" href="mailto:{{ contact_email }}?subject=Rolang%20Beauty%20store%20access">
          Email {{ contact_email }}
        </a>
      </div>
    </section>

    <aside class="rolang-password-panel">
      <div class="rolang-password-showcase">
        <article class="rolang-password-card">
          <div class="rolang-password-card-media">
            <img
              src="{{ 'skin1004-centella-ampoule.png' | asset_url }}"
              alt="SKIN1004 Madagascar Centella Ampoule bottle"
              width="320"
              height="320"
              loading="lazy"
            >
          </div>
          <div class="rolang-password-card-copy">
            <strong>SKIN1004</strong>
            <span>Centella Ampoule</span>
          </div>
        </article>

        <article class="rolang-password-card">
          <div class="rolang-password-card-media">
            <img
              src="{{ 'cosrx-advanced-snail-96-mucin-essence.jpg' | asset_url }}"
              alt="COSRX Advanced Snail 96 Mucin Essence bottle"
              width="320"
              height="320"
              loading="lazy"
            >
          </div>
          <div class="rolang-password-card-copy">
            <strong>COSRX</strong>
            <span>Snail 96 Mucin Essence</span>
          </div>
        </article>

        <article class="rolang-password-card">
          <div class="rolang-password-card-media">
            <img
              src="{{ 'medicube-collagen-niacinamide-jelly-cream.jpg' | asset_url }}"
              alt="Medicube Collagen Niacinamide Jelly Cream jar"
              width="320"
              height="320"
              loading="lazy"
            >
          </div>
          <div class="rolang-password-card-copy">
            <strong>Medicube</strong>
            <span>Jelly Cream</span>
          </div>
        </article>
      </div>

      <div class="rolang-password-form-card">
        {% if shop.password_message != blank %}
          <p class="rolang-password-note">{{ shop.password_message }}</p>
        {% endif %}

        {% form 'storefront_password' %}
          {% if form.errors %}
            <div class="rolang-password-errors">{{ form.errors | default_errors }}</div>
          {% endif %}

          <label for="password-input">{{ 'password.password' | t }}</label>
          <input
            class="rolang-password-input"
            type="password"
            name="password"
            id="password-input"
            autocomplete="current-password"
          >

          <button class="rolang-button rolang-button--wide" type="submit">
            {{ 'password.enter' | t }}
          </button>
        {% endform %}
      </div>
    </aside>
  </div>
</div>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
